<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.yaungyue.secondhand.mapper.ProductMapper">

    <resultMap id="BaseResultMap" type="xyz.yaungyue.secondhand.model.entity.Product">
            <id property="id" column="id" />
            <result property="user_id" column="user_id" />
            <result property="category_id" column="category_id" />
            <result property="title" column="title" />
            <result property="description" column="description" />
            <result property="price" column="price" />
            <result property="stock" column="stock" />
            <result property="locked_stock" column="locked_stock" />
            <result property="main_image" column="main_image" />
            <result property="location" column="location" />
            <result property="status" column="status" />
            <result property="audit_msg" column="audit_msg" />
            <result property="create_time" column="create_time" />
            <result property="update_time" column="update_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,category_id,title,description,price,
        stock,locked_stock,main_image,location,status,
        audit_msg,create_time,update_time
    </sql>
    
    <!-- 根据分类ID统计商品数量 -->
    <select id="selectCountByCategoryId" resultType="int">
        SELECT COUNT(*) FROM bus_product WHERE category_id = #{categoryId}
    </select>
    
    <!-- 根据状态查询商品列表 -->
    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List" />
        FROM bus_product 
        WHERE status = #{status}
        ORDER BY create_time DESC
    </select>
</mapper>